# ══════════════════════════════════════════════════════════
#  SOAC RKU — Backend Environment Variables
#  Copy this file to .env and fill in all values.
#  Never commit .env to version control.
# ══════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=production
# NODE_TLS_REJECT_UNAUTHORIZED=1  # Set to 1 in production

# ── PostgreSQL ───────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DB=soac_rku
PG_USER=postgres
PG_PASSWORD=your-strong-db-password
PG_POOL_MAX=20
PG_IDLE_TIMEOUT=10000
PG_CONN_TIMEOUT=3000
PG_QUERY_TIMEOUT=30000
PG_RETRY_ATTEMPTS=5

# ── Redis (REQUIRED) ─────────────────────────────────────
# Session storage, token blacklist, rate limiting
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=  # Only if Redis requires auth

# ── JWT (ALL REQUIRED — generate unique secrets) ────────
# Generate secrets with: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace-with-different-long-random-secret-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=7d
RESET_PASSWORD_SECRET=replace-with-another-long-random-secret-min-32-chars
RESET_PASSWORD_EXPIRES_IN=30m

# ── Email (SMTP) ─────────────────────────────────────────
# Gmail: use an App Password (not your account password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=noreply@soac-rku.com

# ── Frontend URL (REQUIRED in production) ────────────────
# Must match the exact origin of your frontend (no trailing slash)
CLIENT_URL=https://your-domain.com

# ── Admin Email (REQUIRED in production) ─────────────────
ADMIN_EMAIL=admin@rku.ac.in

# ── External APIs ────────────────────────────────────────
# NewsAPI — free key at https://newsapi.org/register (100 req/day)
NEWS_API_KEY=your-newsapi-key
# YouTube Data API v3 — https://console.cloud.google.com → YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key
