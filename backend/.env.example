# ══════════════════════════════════════════════════════════
#  SOAC RKU — Backend Environment Variables
#  Copy this file to .env and fill in all values.
#  Never commit .env to version control.
# ══════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── PostgreSQL ───────────────────────────────────────────
# OPTION A — Railway: paste the DATABASE_URL from your Railway PostgreSQL plugin
# DATABASE_URL=postgresql://user:password@host:5432/railway

# OPTION B — Local / manual: fill individual vars
PG_HOST=localhost
PG_PORT=5432
PG_DB=soac_rku
PG_USER=postgres
PG_PASSWORD=your-strong-db-password
PG_POOL_MAX=20
PG_IDLE_TIMEOUT=10000
PG_CONN_TIMEOUT=3000
PG_QUERY_TIMEOUT=30000
PG_RETRY_ATTEMPTS=5

# ── Redis ─────────────────────────────────────────────────
# OPTION A — Railway: paste the REDIS_URL from your Railway Redis plugin
# REDIS_URL=redis://:password@host:6379

# OPTION B — Local / manual
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=  # Only if Redis requires auth

# ── JWT (ALL REQUIRED — generate unique secrets) ────────
# Generate: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace-with-different-long-random-secret-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=7d
RESET_PASSWORD_SECRET=replace-with-another-long-random-secret-min-32-chars
RESET_PASSWORD_EXPIRES_IN=30m

# ── Email / SMTP (optional — app runs without it) ────────
# Gmail: generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=noreply@soac-rku.com

# ── Frontend URL (REQUIRED in production) ────────────────
# Your Vercel frontend URL — no trailing slash
CLIENT_URL=https://your-app.vercel.app

# ── Admin Email (REQUIRED in production) ─────────────────
ADMIN_EMAIL=admin@rku.ac.in

# ── External APIs (optional) ─────────────────────────────
NEWS_API_KEY=your-newsapi-key
YOUTUBE_API_KEY=your-youtube-api-key
